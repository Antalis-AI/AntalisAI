# syntax=docker/dockerfile:1
# ──────────────────────────────────────────────
#  Stage 1 : Build SvelteKit frontend
# ──────────────────────────────────────────────
FROM --platform=$BUILDPLATFORM node:22-alpine3.20 AS build

ARG BUILD_HASH=dev-build
ENV APP_BUILD_HASH=${BUILD_HASH}

WORKDIR /app

RUN apk add --no-cache git

COPY package.json package-lock.json ./
RUN npm ci --force

COPY --exclude=backend . .
RUN npm run build

# ──────────────────────────────────────────────
#  Stage 2 : Serve with nginx
# ──────────────────────────────────────────────
FROM nginx:stable-alpine AS frontend

# Copy built SvelteKit output
COPY --from=build /app/build /usr/share/nginx/html

# URL du backend, configurable au lancement : docker run -e BACKEND_URL=http://mon-backend:8080
ENV BACKEND_URL=http://localhost:8080

# Nginx config via template - envsubst remplace BACKEND_URL au démarrage du conteneur
RUN mkdir -p /etc/nginx/templates && \
    printf 'server {\n\
    listen 80;\n\
    server_name _;\n\
    root /usr/share/nginx/html;\n\
    index index.html;\n\
\n\
    location /api/ {\n\
        proxy_pass ${BACKEND_URL};\n\
        proxy_set_header Host $host;\n\
        proxy_set_header X-Real-IP $remote_addr;\n\
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;\n\
        proxy_set_header X-Forwarded-Proto $scheme;\n\
    }\n\
\n\
    location /ws/ {\n\
        proxy_pass ${BACKEND_URL};\n\
        proxy_http_version 1.1;\n\
        proxy_set_header Upgrade $http_upgrade;\n\
        proxy_set_header Connection "upgrade";\n\
        proxy_set_header Host $host;\n\
        proxy_read_timeout 86400;\n\
    }\n\
\n\
    location / {\n\
        try_files $uri $uri/ /index.html;\n\
    }\n\
}\n' > /etc/nginx/templates/default.conf.template && \
    rm -f /etc/nginx/conf.d/default.conf

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD wget -qO- http://localhost/ || exit 1

CMD ["nginx", "-g", "daemon off;"]
